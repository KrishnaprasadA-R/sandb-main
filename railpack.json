{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "build": {
      "commands": [
        "...",
        "python manage.py collectstatic --noinput"
      ]
    }
  },
  "deploy": {
    "startCommand": "python manage.py migrate && gunicorn --bind 0.0.0.0:${PORT:-8000} sbspices_site.wsgi"
  }
}
