{
  "$schema": "https://schema.railpack.com",
  "steps": {
    "install": {
      "commands": ["pip install -r requirements.txt"]
    },
    "build": {
      "commands": ["python manage.py collectstatic --noinput"]
    }
  },
  "deploy": {
    "startCommand": "python manage.py migrate && gunicorn sbspices_site.wsgi"
  }
}
